<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Event Dashboard</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            margin: 0;
            padding: 20px;
            color: #333;
        }

        h1 {
            text-align: center;
            color: #fff;
            margin-bottom: 30px;
        }

        h3 {
            margin-top: 0;
        }

        #main-event-add-container,
        #all-events-container {
            background: #fff;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            margin-bottom: 30px;
            animation: fadeIn 0.8s ease-in-out;
        }

        form label {
            font-weight: bold;
        }

        form input,
        form select,
        form textarea {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
            outline: none;
            transition: border 0.3s, box-shadow 0.3s;
        }

        form input:focus,
        form select:focus,
        form textarea:focus {
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102,126,234,0.6);
        }

        textarea {
            resize: none; /* textarea resize disabled */
            height: 80px;
        }

        button {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            transition: transform 0.2s, background 0.3s, box-shadow 0.3s;
        }

        button:hover {
            background: #5a67d8;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        button:active {
            transform: scale(0.96);
        }

        #bttn-container {
            margin-bottom: 15px;
            display: flex;
            gap: 10px;
        }

        .event-card {
            background: #f7f7ff;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            position: relative;
            animation: slideUp 0.5s ease;
        }

        .event-card h4 {
            margin: 0 0 5px 0;
            color: #333;
        }

        .event-card span {
            font-size: 13px;
            color: #555;
        }

        .event-card p {
            margin-top: 8px;
            font-size: 14px;
        }

        #dltevent {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #ff4d4d;
            border-radius: 50%;
            width: 28px;
            height: 28px;
            font-size: 14px;
            padding: 0;
        }

        #dltevent:hover {
            background: #e63939;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <h1>🎯Smart Event Dashboard</h1>

    <div id="main-event-add-container">
        <h3>Add New Event</h3>
        <form>
            <label>Event Title:</label>
            <input type="text" id="EventTitle" required>

            <br><br>

            <label>Event Date:</label>
            <input type="date" id="EventDate" required>

            <br><br>

            <label>Category:</label>
            <select id="EventCategory" required>
                <option>Conference</option>
                <option>Workshop</option>
                <option>Meetup</option>
                <option>Webinar</option>
                <option>Social</option>
            </select>

            <br><br>

            <label>Description:</label>
            <textarea id="EventDescription" required></textarea>

            <br><br>

            <button type="submit">Add Event</button>
        </form>
    </div>

    <div>
        <h3 style="color:white;">MY EVENTS</h3>

        <div id="bttn-container">
            <button id="clear-event-btn">Clear All Events</button>
            <button id="add-sample-event">Add Sample Events</button>
        </div>

        <div id="all-events-container">
            No Events Yet.
        </div>
    </div>

    <script>
        let form = document.querySelector('form')
        let EventTitle = document.querySelector('#EventTitle')
        let EventDate = document.querySelector('#EventDate')
        let EventCategory = document.querySelector('#EventCategory')
        let EventDescription = document.querySelector('#EventDescription')
        let alleventscontainer = document.querySelector('#all-events-container')
        let ClearAllEvents = document.querySelector('#clear-event-btn')

        function addEventFunction(event) {
            event.preventDefault()

            let card = document.createElement('div')
            card.classList.add('event-card')

            card.innerHTML = `
                <button id="dltevent">X</button>
                <h4>${EventTitle.value}</h4>
                <span>${EventDate.value}</span><br>
                <span>${EventCategory.value}</span>
                <p>${EventDescription.value}</p>
            `

            alleventscontainer.innerHTML = ""
            alleventscontainer.append(card)

            form.reset()
        }

        function ClearAllEventsfunction() {
            alleventscontainer.innerHTML = `<h4>No events yet</h4>`
        }

        ClearAllEvents.addEventListener('click', ClearAllEventsfunction)
        form.addEventListener('submit', addEventFunction)
    </script>

</body>
</html>
